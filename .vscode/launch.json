{
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "name": "Npm  Dev",
      "request": "launch",
      "runtimeExecutable": "npm",
      "args": [
        "run",
        "start:dev"
      ],
      "console": "integratedTerminal"
    },
    {
      "name": "Chrome Dev",
      "type": "chrome",
      "request": "launch",
      // "preLaunchTask": "npm: start",
      "url": "http://localhost:4202/",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true,
      "trace": true,
    }
  ],
  "compounds": [
    {
      "name": "Start Dev",
      "configurations": [
        "Npm  Dev",
        "Chrome Dev",
      ]
    }
  ]
}