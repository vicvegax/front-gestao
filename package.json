{
  "name": "front-gestao",
  "version": "0.26.0312",
  "scripts": {
    "ng": "ng",
    "prebuild": "node scripts/geraVersao.cjs",
    "build": "ng build --configuration production --base-href=/pai/ --output-hashing=all",
    "start": "ng serve",
    "start:dev": "ng serve --configuration development --port 4202"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^20.2.14",
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/material": "^20.2.14",
    "@angular/material-luxon-adapter": "^20.2.14",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "@tailwindcss/postcss": "^4.1.18",
    "decimal.js": "^10.6.0",
    "luxon": "^3.7.2",
    "ngx-mask": "^20.0.3",
    "pdfmake": "^0.3.3",
    "postcss": "^8.5.6",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.1.18",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.5",
    "@angular/cli": "^20.3.5",
    "@angular/compiler-cli": "^20.3.0",
    "@types/luxon": "^3.7.1",
    "@types/pdfmake": "^0.3.1",
    "typescript": "~5.9.2"
  }
}
